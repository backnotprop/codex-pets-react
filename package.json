{
  "name": "codex-pets-react",
  "version": "0.2.0",
  "description": "Declarative React wrapper for Codex pet spritesheets.",
  "license": "MIT",
  "author": "backnotprop",
  "homepage": "https://backnotprop.github.io/codex-pets-react/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backnotprop/codex-pets-react.git"
  },
  "bugs": {
    "url": "https://github.com/backnotprop/codex-pets-react/issues"
  },
  "type": "module",
  "main": "./dist/lib/index.cjs",
  "module": "./dist/lib/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    }
  },
  "files": [
    "dist/lib",
    "dist/types",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --config examples/plannotator-pet/vite.config.ts --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:example": "vite build --config examples/plannotator-pet/vite.config.ts",
    "build": "npm run typecheck && npm run build:types && npm run build:lib && npm run build:example",
    "preview": "vite preview --config examples/plannotator-pet/vite.config.ts --host 127.0.0.1",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codex",
    "pets",
    "spritesheet",
    "react",
    "animation"
  ],
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "sideEffects": false
}
